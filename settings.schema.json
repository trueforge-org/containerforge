{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "./settings.schema.json",
  "title": "Container Settings",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "upstream_env_url",
    "ports",
    "env",
    "volumes"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "ports": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "port",
          "protocol",
          "required"
        ],
        "properties": {
          "port": {
            "type": "integer",
            "minimum": 1,
            "maximum": 65535
          },
          "protocol": {
            "type": "string",
            "enum": [
              "tcp",
              "udp",
              "sctp"
            ]
          },
          "required": {
            "type": "boolean"
          }
        }
      }
    },
    "env": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "default",
          "required"
        ],
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
          },
          "default": {
            "type": "string"
          },
          "required": {
            "type": "boolean"
          }
        }
      }
    },
    "volumes": {
      "type": "array",
      "minItems": 1,
      "contains": {
        "type": "object",
        "required": [
          "path"
        ],
        "properties": {
          "path": {
            "const": "/config"
          }
        }
      },
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "required"
        ],
        "properties": {
          "path": {
            "type": "string",
            "pattern": "^/"
          },
          "required": {
            "type": "boolean"
          }
        }
      }
    },
    "upstream_env_url": {
      "type": "string",
      "description": "URL to upstream environment variable documentation"
    },
    "dependencies": {
      "type": "array",
      "description": "Other containers in this repository that this container depends on at runtime",
      "items": {
        "$ref": "#/$defs/dependency"
      }
    },
    "opt_dependencies": {
      "type": "array",
      "description": "Other containers in this repository that this container can optionally use at runtime",
      "items": {
        "$ref": "#/$defs/dependency"
      }
    }
  },
  "$defs": {
    "dependency": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "image"
      ],
      "properties": {
        "image": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._-]*$"
        }
      }
    }
  }
}
